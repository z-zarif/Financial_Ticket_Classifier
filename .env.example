# Copy this file to .env and fill in real values locally.
# Do NOT commit real values.

# High-value threshold in BDT. Transactions at or above this amount
# always set human_review_required=true.
HIGH_VALUE_THRESHOLD=50000

# Server port (used by uvicorn / Dockerfile).
PORT=8000

# Optional: enable LLM-based refinement of customer_reply (off by default).
# Requires OPENAI_API_KEY when enabled.
USE_LLM_REPLY=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini